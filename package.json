{
  "name": "ece493-lab2-cms-registration",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node src/server.js",
    "test": "vitest run --coverage",
    "test:coverage:c8": "vitest run --coverage && c8 --all=false --reporter=none node scripts/assert-branch-coverage.mjs coverage/lcov.info",
    "test:acceptance": "vitest run tests/acceptance/*.acceptance.test.js",
    "test:acceptance:uc01": "vitest run tests/acceptance/uc-01-registration.acceptance.test.js",
    "test:acceptance:uc02": "vitest run tests/acceptance/uc-02-login.acceptance.test.js",
    "test:acceptance:uc03": "vitest run tests/acceptance/uc03-change-password.acceptance.test.js",
    "test:acceptance:uc04": "vitest run tests/acceptance/uc-04-submission.acceptance.test.js",
    "test:acceptance:uc04:performance": "vitest run tests/acceptance/uc-04-performance.test.js",
    "test:integration:auth": "vitest run tests/integration/auth-api.integration.test.js",
    "test:integration:password-change": "vitest run tests/integration/password-change-*.integration.test.js",
    "test:integration:submission": "vitest run tests/integration/paper-submission.integration.test.js",
    "test:performance:auth": "vitest run tests/integration/auth-api.performance.test.js",
    "ci:sc002": "npm run test:acceptance:uc04:performance",
    "lint": "eslint ."
  },
  "dependencies": {
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.22.0",
    "jsdom": "^26.0.0",
    "supertest": "^7.0.0",
    "vitest": "^3.2.4"
  }
}
